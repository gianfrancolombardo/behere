---
import Icon from '../ui/Icon.astro';
import PlaceholderImage from '../ui/PlaceholderImage.astro';
import type { LandingContent } from '../../content/types';

interface Props {
  problem: LandingContent['problem'];
  imageAlt?: string;
}

const { problem, imageAlt = 'Experiencia en vivo afectada por pantallas' } = Astro.props;
const paragraphs = problem.body.split('\n\n');
---

<section class="section-padding">
  <div class="container-main">
    <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center lg:gap-16">
      <div class="reveal">
        <h2 class="max-w-md font-display text-3xl font-bold leading-tight md:text-4xl">
          {problem.title}
        </h2>
        <div class="mt-6 max-w-md space-y-4 text-text-muted">
          {paragraphs.map((p) => <p class="leading-relaxed">{p}</p>)}
        </div>
        {
          problem.transition && (
            <p class="mt-6 max-w-md border-l-2 border-purple-glow pl-4 font-medium text-text">
              {problem.transition}
            </p>
          )
        }
      </div>
      <PlaceholderImage aspect="portrait" alt={imageAlt} tilt="left" class="reveal reveal-delay-1 mx-auto w-full max-w-sm lg:mx-0 lg:ml-auto" />
    </div>

    <div class="mt-16 md:mt-20">
      {
        problem.painPoints.map((point, index) => (
          <div
            class:list={[
              'reveal grid grid-cols-[3.5rem_1fr] items-center gap-x-4 border-t border-border/60 py-7 md:grid-cols-[4.5rem_2.5rem_1fr] md:gap-x-6',
              index === 0 && 'border-t-0 md:border-t',
            ]}
          >
            <span
              class="ghost-numeral !text-[3rem] leading-none md:!text-[3.75rem]"
              aria-hidden="true"
            >
              {String(index + 1).padStart(2, '0')}
            </span>
            <div class="flex h-10 w-10 items-center justify-center border border-purple-glow/30 bg-purple-glow/10 text-purple-muted md:row-span-1" style="border-radius: 6px;">
              <Icon name={point.icon} size={18} />
            </div>
            <div class="col-start-2 min-w-0 md:col-start-3">
              <h3 class="font-display text-lg font-semibold">{point.title}</h3>
              <p class="mt-2 max-w-lg text-sm leading-relaxed text-text-muted">{point.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
