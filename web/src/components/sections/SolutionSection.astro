---
import Icon from '../ui/Icon.astro';
import ComparisonTable from './ComparisonTable.astro';
import type { LandingContent } from '../../content/types';

interface Props {
  solution: LandingContent['solution'];
}

const { solution } = Astro.props;
const paragraphs = solution.body.split('\n\n');
const [first, second, third] = solution.pillars;
---

<section class="section-padding bg-surface/20">
  <div class="container-main">
    <div class="max-w-2xl reveal">
      <h2 class="font-display text-3xl font-bold leading-tight md:text-4xl">{solution.title}</h2>
      <div class="mt-6 space-y-4 text-text-muted">
        {paragraphs.map((p) => <p class="leading-relaxed">{p}</p>)}
      </div>
    </div>

    <div class="mt-12 grid gap-4 md:grid-cols-3 md:grid-rows-2 md:gap-4">
      {
        first && (
          <div class="reveal relative flex flex-col justify-between overflow-hidden border border-purple-glow/30 bg-gradient-to-br from-purple-deep/50 via-surface to-surface p-7 md:col-span-2 md:row-span-2 md:p-9" style="border-radius: 6px;">
            <div>
              <div class="flex h-11 w-11 items-center justify-center border border-purple-glow/40 bg-purple-glow/15 text-purple-muted" style="border-radius: 6px;">
                <Icon name={first.icon} size={22} />
              </div>
              <h3 class="mt-5 font-display text-2xl font-semibold">{first.title}</h3>
              <p class="mt-3 max-w-md text-sm leading-relaxed text-text-muted md:text-base">{first.copy}</p>
            </div>
            <span class="mt-8 font-display text-xs font-bold uppercase tracking-[0.14em] text-purple-muted/70">
              {first.headline}
            </span>
          </div>
        )
      }

      {
        [second, third].filter(Boolean).map((pillar, i) => (
          <div
            class:list={['reveal', i === 0 ? 'reveal-delay-1' : 'reveal-delay-2', 'panel flex flex-col justify-between p-6 md:col-start-3']}
            style={`grid-row-start: ${i + 1};`}
          >
            <div>
              <div class="flex h-10 w-10 items-center justify-center bg-accent/10 text-accent" style="border-radius: 6px;">
                <Icon name={pillar!.icon} size={18} />
              </div>
              <h3 class="mt-4 font-display text-lg font-semibold">{pillar!.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-text-muted">{pillar!.copy}</p>
            </div>
          </div>
        ))
      }
    </div>

    {
      solution.comparison && (
        <div class="mt-14 reveal">
          <ComparisonTable comparison={solution.comparison} />
        </div>
      )
    }
  </div>
</section>
