---
import Icon from '../ui/Icon.astro';
import type { LandingContent } from '../../content/types';

interface Props {
  profiles: NonNullable<LandingContent['profiles']>;
}

const { profiles } = Astro.props;
---

<section class="section-padding">
  <div class="container-main">
    <h2 class="reveal font-display text-3xl font-bold md:text-4xl">{profiles.title}</h2>

    <div class="scroll-rail mt-10 flex snap-x snap-mandatory gap-4 overflow-x-auto pb-2 md:mt-12 md:grid md:grid-cols-3 md:overflow-visible">
      {
        profiles.items.map((profile, index) => (
          <div
            class:list={[
              'reveal panel w-[80%] shrink-0 snap-start p-6 sm:w-[60%] md:w-auto',
              index === 1 && 'reveal-delay-1',
              index === 2 && 'reveal-delay-2',
            ]}
          >
            <div class="flex h-10 w-10 items-center justify-center border border-purple-glow/30 bg-purple-glow/10 text-purple-muted" style="border-radius: 6px;">
              <Icon name={profile.icon} size={18} />
            </div>
            <h3 class="mt-4 font-display text-lg font-semibold">{profile.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-text-muted">{profile.description}</p>
          </div>
        ))
      }
    </div>

    <p class="reveal mt-10 text-text-muted">{profiles.inclusion}</p>
  </div>
</section>
