---
import Button from '../ui/Button.astro';
import PilotForm from '../forms/PilotForm.astro';
import type { LandingContent } from '../../content/types';

interface Props {
  finalCta: LandingContent['finalCta'];
  variant: 'b2b' | 'b2c';
  pilotForm?: LandingContent['pilotForm'];
  tagline?: string;
}

const { finalCta, variant, pilotForm, tagline } = Astro.props;
const isB2B = variant === 'b2b';
---

<section class="section-padding relative overflow-hidden border-t border-border">
  <div
    class="pointer-events-none absolute inset-0 bg-gradient-to-t from-purple-deep/30 via-transparent to-transparent"
    aria-hidden="true"
  >
  </div>
  <div class="container-main relative">
    <div class="reveal mx-auto max-w-2xl text-center">
      <h2 class="font-display text-4xl font-bold leading-tight md:text-5xl">{finalCta.title}</h2>
      <p class="mt-4 text-lg text-text-muted">{finalCta.subtitle}</p>
      {
        !isB2B && (
          <div class="mt-8">
            <Button variant="primary" betaTrigger dataCta="final-cta">
              {finalCta.cta}
            </Button>
            {tagline && <p class="mt-5 font-display text-sm font-bold text-accent">{tagline}</p>}
          </div>
        )
      }
      {finalCta.riskReversal && <p class="mt-6 text-sm text-text-muted">{finalCta.riskReversal}</p>}
    </div>

    {
      isB2B && pilotForm && (
        <div class="reveal reveal-delay-1 mx-auto mt-12 max-w-2xl">
          <PilotForm
            id="pilot-form-final"
            actTypeOptions={pilotForm.actTypeOptions}
            microcopy={pilotForm.microcopy}
            successMessage={pilotForm.successMessage}
          />
        </div>
      )
    }
  </div>
</section>
