---
import { Check, X } from '@lucide/astro';
import type { LandingContent } from '../../content/types';

interface Props {
  comparison: NonNullable<LandingContent['solution']['comparison']>;
}

const { comparison } = Astro.props;
---

<div class="panel overflow-hidden">
  <div class="grid md:grid-cols-2">
    <div class="border-b border-border/50 p-5 md:border-b-0 md:border-r md:p-6">
      <p class="font-display text-sm font-semibold text-text-muted md:text-base">
        {comparison.competitorLabel}
      </p>
      <ul class="mt-5 space-y-5">
        {
          comparison.rows.map((row) => (
            <li>
              <p class="text-xs font-semibold uppercase tracking-[0.12em] text-purple-muted">
                {row.label}
              </p>
              <p class="mt-1.5 flex items-start gap-2.5 text-sm leading-relaxed text-text-muted">
                <X size={16} class="mt-0.5 shrink-0 text-text-muted/40" aria-hidden="true" />
                {row.competitor}
              </p>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="bg-accent/5 p-5 md:p-6">
      <p class="font-display text-sm font-semibold text-accent md:text-base">
        {comparison.behereLabel}
      </p>
      <ul class="mt-5 space-y-5">
        {
          comparison.rows.map((row) => (
            <li>
              <p class="text-xs font-semibold uppercase tracking-[0.12em] text-accent/70">
                {row.label}
              </p>
              <p class="mt-1.5 flex items-start gap-2.5 text-sm font-medium leading-relaxed text-text">
                <Check size={16} class="mt-0.5 shrink-0 text-accent" aria-hidden="true" />
                {row.behere}
              </p>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</div>
