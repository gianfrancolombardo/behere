---
import '../styles/global.css';
import SiteHeader from '../components/layout/SiteHeader.astro';
import SiteFooter from '../components/layout/SiteFooter.astro';
import type { LandingSEO } from '../content/types';

interface Props {
  seo: LandingSEO;
  current: 'b2b' | 'b2c';
  stickyCta: string;
  stickyVariant: 'header' | 'footer';
}

const { seo, current, stickyCta, stickyVariant } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const umamiWebsiteId =
  import.meta.env.PUBLIC_UMAMI_WEBSITE_ID ?? '18ee3c65-c408-45b3-8203-190d545762ee';
const umamiScriptUrl =
  import.meta.env.PUBLIC_UMAMI_SCRIPT_URL ?? 'https://cloud.umami.is/script.js';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={seo.ogTitle} />
    <meta property="og:description" content={seo.ogDescription} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.ogTitle} />
    <meta name="twitter:description" content={seo.ogDescription} />
    {
      umamiWebsiteId && (
        <script
          defer
          src={umamiScriptUrl}
          data-website-id={umamiWebsiteId}
          data-domains="trybehere.com,www.trybehere.com,localhost,127.0.0.1"
        />
      )
    }
  </head>
  <body class="min-h-screen overflow-x-hidden" data-landing={current}>
    <SiteHeader {current} {stickyCta} {stickyVariant} />
    <main class="pt-16">
      <slot />
    </main>
    <SiteFooter />
    <slot name="scripts" />
    <script>
      import { initAnalytics, type LandingType } from '../lib/analytics';

      const landing = document.body.dataset.landing as LandingType;
      if (landing) initAnalytics(landing);
    </script>
    <script>
      const revealables = document.querySelectorAll('.reveal');
      if (revealables.length) {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-in');
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.15, rootMargin: '0px 0px -40px 0px' },
        );
        revealables.forEach((el) => observer.observe(el));
      }
    </script>
  </body>
</html>
